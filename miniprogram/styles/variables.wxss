/* styles/variables.wxss - 设计Token */

/* ===== 暖色主题 ===== */
page {
  /* 主色调 - 珊瑚橙 */
  --color-primary: #FF8C6B;
  --color-primary-light: #FFB088;
  --color-primary-dark: #FF6B4A;
  --color-primary-gradient: linear-gradient(135deg, #FF8C6B 0%, #FF6B4A 100%);

  /* 功能色 */
  --color-success: #4ECDC4;
  --color-success-bg: rgba(78, 205, 196, 0.1);
  --color-success-border: rgba(78, 205, 196, 0.3);
  --color-warning: #FFE66D;
  --color-danger: #FF6B6B;
  --color-danger-bg: rgba(255, 107, 107, 0.08);
  --color-danger-border: rgba(255, 107, 107, 0.25);
  --color-info: #95E1D3;

  /* 背景色 */
  --bg-primary: #FFF9F6;
  --bg-secondary: #FFFFFF;
  --bg-card: #FFFFFF;
  --bg-overlay: rgba(0, 0, 0, 0.5);

  /* 文字色 */
  --text-primary: #2D2D3A;
  --text-secondary: #5A5A72;
  --text-placeholder: #B8B8C8;
  --text-hint: #999999;
  --text-white: #FFFFFF;

  /* 边框 */
  --border-color: #F0E8E3;
  --border-radius-sm: 12rpx;
  --border-radius-md: 20rpx;
  --border-radius-lg: 32rpx;
  --border-radius-xl: 48rpx;
  --border-radius-round: 50%;

  /* 间距 */
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;
  --spacing-xxl: 64rpx;

  /* 字号 */
  --font-size-xs: 24rpx;
  --font-size-sm: 28rpx;
  --font-size-md: 32rpx;
  --font-size-lg: 36rpx;
  --font-size-xl: 40rpx;
  --font-size-xxl: 56rpx;

  /* 阴影 */
  --shadow-sm: 0 2rpx 8rpx rgba(45, 45, 58, 0.06);
  --shadow-md: 0 4rpx 16rpx rgba(45, 45, 58, 0.08);
  --shadow-lg: 0 8rpx 32rpx rgba(45, 45, 58, 0.12);
  --shadow-card: 0 4rpx 24rpx rgba(255, 140, 107, 0.12);

  /* 动画 */
  --transition-fast: 0.2s ease;
  --transition-normal: 0.3s ease;
  --transition-slow: 0.5s ease;
}

/* 记录类型颜色映射 */
page {
  --type-feeding: #FF8C6B;
  --type-diaper: #4ECDC4;
  --type-sleep: #7C83FD;
  --type-mood: #FFE66D;
  --type-food: #95E1D3;
  --type-health: #FF6B6B;
}

/* 记录类型背景色（浅色） */
page {
  --type-feeding-bg: rgba(255, 140, 107, 0.1);
  --type-diaper-bg: rgba(78, 205, 196, 0.1);
  --type-sleep-bg: rgba(124, 131, 253, 0.1);
  --type-mood-bg: rgba(255, 230, 109, 0.15);
  --type-food-bg: rgba(149, 225, 211, 0.1);
  --type-health-bg: rgba(255, 107, 107, 0.1);
}
