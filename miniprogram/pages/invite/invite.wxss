/* pages/invite/invite.wxss */
.invite-page {
  min-height: 100vh; background: var(--bg-primary);
  display: flex; align-items: center; justify-content: center;
  padding: 40rpx;
}

.invite-card {
  width: 100%; background: var(--bg-card);
  border-radius: var(--border-radius-xl);
  padding: 0; text-align: center;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
  overflow: hidden;
}

/* 模式切换标签 */
.mode-tabs {
  display: flex;
  background: var(--bg-primary);
  padding: 12rpx 12rpx 0 12rpx;
  margin: 0;
}
.tab-btn {
  flex: 1; height: 80rpx; line-height: 80rpx;
  text-align: center; font-size: var(--font-size-sm);
  color: var(--text-secondary); border-radius: var(--border-radius-lg) var(--border-radius-lg) 0 0;
  transition: all 0.3s;
  background: transparent;
  margin: 0;
}
.tab-btn.active {
  background: var(--bg-card);
  color: var(--color-primary); font-weight: 600;
  border-bottom: 4rpx solid var(--color-primary);
  margin-bottom: -4rpx;
  z-index: 1;
  padding-bottom: 0;
}

/* 标签页内容 */
.tab-content {
  padding: 48rpx 32rpx;
  background: var(--bg-card);
  min-height: 500rpx;
}

.invite-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.invite-title { display: block; font-size: var(--font-size-lg); font-weight: 700; color: var(--text-primary); margin-bottom: 8rpx; }
.invite-desc { display: block; font-size: var(--font-size-sm); color: var(--text-secondary); line-height: 1.6; margin-bottom: 32rpx; }

/* 加入成功卡片样式 */
.joined-card .success-icon {
  font-size: 120rpx; margin-bottom: 24rpx;
  animation: bounce 0.6s ease-out;
}
@keyframes bounce {
  0% { transform: scale(0); }
  50% { transform: scale(1.2); }
  100% { transform: scale(1); }
}

.invite-code-section { margin-bottom: 32rpx; }
.code-label { display: block; font-size: var(--font-size-xs); color: var(--text-hint); margin-bottom: 12rpx; text-align: left; }
.code-display {
  background: var(--bg-primary); border-radius: var(--border-radius-lg);
  padding: 32rpx; margin-bottom: 20rpx;
  border: 2rpx dashed rgba(255, 140, 107, 0.3);
}
.code-text { font-size: 48rpx; font-weight: 700; color: var(--color-primary); letter-spacing: 12rpx; }
.code-actions { display: flex; gap: 16rpx; }
.code-btn {
  flex: 1; height: 80rpx; line-height: 80rpx;
  border-radius: var(--border-radius-lg); font-size: var(--font-size-sm);
  font-weight: 500; text-align: center;
}
.copy-btn { background: linear-gradient(135deg, #FF8C6B, #FF6B4A); color: #fff; }
.share-btn { background: rgba(255, 140, 107, 0.1); color: var(--color-primary); }

/* 输入框样式 */
.input-section { margin-bottom: 32rpx; }
.code-input {
  width: 100%; height: 88rpx; line-height: 88rpx;
  background: var(--bg-primary); border-radius: var(--border-radius-lg);
  padding: 0 24rpx; margin-bottom: 20rpx;
  font-size: var(--font-size-lg); font-weight: 700;
  color: var(--color-primary); text-align: center;
  letter-spacing: 12rpx; border: 2rpx solid transparent;
  box-sizing: border-box;
}
.code-input:focus {
  border-color: rgba(255, 140, 107, 0.5);
  background: #fff;
}
.join-btn {
  background: linear-gradient(135deg, #FF8C6B, #FF6B4A); color: #fff;
}

.invite-tips { text-align: left; }
.tip-item {
  display: block; font-size: var(--font-size-xs); color: var(--text-hint);
  line-height: 2.2;
}


