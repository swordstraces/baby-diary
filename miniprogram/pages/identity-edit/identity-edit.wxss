/* identity-edit 页面样式 */
.identity-edit-page {
  min-height: 100vh;
  background: var(--bg-primary);
  padding: 32rpx;
}

.form-item {
  margin-bottom: 48rpx;
}

.form-label {
  display: block;
  font-size: var(--font-size-sm);
  font-weight: 500;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

/* 头像按钮 */
.avatar-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 200rpx !important;
  height: 200rpx !important;
  border-radius: 50% !important;
  padding: 0 !important;
  background: linear-gradient(135deg, #FF8C6B, #FFB088);
  box-shadow: 0 8rpx 24rpx rgba(255, 140, 107, 0.3);
  overflow: hidden;
  border: none !important;
  margin: 0 auto;
  box-sizing: border-box !important;
  position: relative;
  line-height: normal !important;
  font-size: 0 !important;
}

.avatar-btn::after {
  border: none !important;
  content: none !important;
}

.avatar-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 50%;
  display: block;
}

.avatar-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

.placeholder-icon {
  font-size: 56rpx;
  margin-bottom: 8rpx;
}

.placeholder-text {
  font-size: var(--font-size-xs);
  color: rgba(255, 255, 255, 0.9);
}

/* 昵称输入 */
.nickname-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  font-size: var(--font-size-base);
  color: var(--text-primary);
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.nickname-input:focus {
  border-color: var(--color-primary);
}

.input-hint {
  display: block;
  text-align: right;
  font-size: var(--font-size-xs);
  color: var(--text-hint);
  margin-top: 8rpx;
}

/* 身份选择器 */
.identity-picker {
  width: 100%;
}

.picker-display {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
}

.picker-text {
  font-size: var(--font-size-base);
  color: var(--text-primary);
}

.picker-arrow {
  font-size: 40rpx;
  color: var(--text-hint);
  font-weight: 300;
}

/* 操作按钮 */
.action-buttons {
  margin-top: 64rpx;
}

.btn-save {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: var(--font-size-base);
  font-weight: 500;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #FF8C6B, #FF6B4A);
  color: white;
  box-shadow: 0 8rpx 24rpx rgba(255, 140, 107, 0.3);
}

.btn-save:active {
  opacity: 0.8;
}
