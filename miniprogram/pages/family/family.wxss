/* 家庭管理页样式 */
.family-page {
  min-height: 100vh; background: var(--bg-primary);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 家庭信息卡 */
.family-card {
  margin: 24rpx; padding: 32rpx;
  background: linear-gradient(135deg, #7C83FD, #6C63FF);
  border-radius: var(--border-radius-xl);
  color: #fff;
  box-shadow: 0 8rpx 32rpx rgba(108, 99, 255, 0.3);
}
.family-header { display: flex; align-items: center; gap: 20rpx; }
.family-icon { font-size: 48rpx; }
.family-info { display: flex; flex-direction: column; }
.family-name { font-size: var(--font-size-lg); font-weight: 700; }
.family-meta { font-size: var(--font-size-xs); opacity: 0.8; margin-top: 4rpx; }

/* 无家庭 */
.no-family {
  display: flex; flex-direction: column; align-items: center;
  padding: 80rpx 24rpx;
}
.no-family-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.no-family-text { font-size: var(--font-size-lg); font-weight: 600; color: var(--text-primary); margin-bottom: 12rpx; }
.no-family-desc { font-size: var(--font-size-sm); color: var(--text-secondary); margin-bottom: 48rpx; }
.no-family .action-card { width: 100%; max-width: 600rpx; }

/* 区块 */
.section { margin: 24rpx; }
.section-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 16rpx;
}
.section-title { font-size: var(--font-size-lg); font-weight: 600; color: var(--text-primary); }
.section-add {
  font-size: var(--font-size-sm);
  color: #fff;
  font-weight: 500;
  background: linear-gradient(135deg, #FF8C6B, #FF6B4A);
  padding: 8rpx 20rpx;
  border-radius: var(--border-radius-lg);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 74, 0.2);
  transition: all 0.3s;
}
.section-add:active {
  transform: scale(0.95);
  opacity: 0.9;
}

.empty-members { padding: 40rpx; text-align: center; }
.empty-text { font-size: var(--font-size-sm); color: var(--text-hint); }

/* 宝宝卡片 */
.baby-card {
  display: flex; align-items: center; gap: 20rpx;
  padding: 24rpx; background: var(--bg-card);
  border-radius: var(--border-radius-lg);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}
.baby-icon { font-size: 48rpx; }
.baby-detail { display: flex; flex-direction: column; gap: 4rpx; }
.baby-name { font-size: var(--font-size-md); font-weight: 600; color: var(--text-primary); }
.baby-meta { font-size: var(--font-size-xs); color: var(--text-hint); }

/* 邀请或加入卡片 */
.action-card {
  background: var(--bg-card);
  border-radius: var(--border-radius-xl);
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}
.action-item {
  display: flex; align-items: center; gap: 24rpx;
  padding: 32rpx 24rpx;
  transition: all 0.2s;
}
.action-item:active {
  background: var(--bg-secondary);
}
.action-icon {
  font-size: 48rpx;
  flex-shrink: 0;
}
.action-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.action-title {
  font-size: var(--font-size-md);
  font-weight: 600;
  color: var(--text-primary);
}
.action-desc {
  font-size: var(--font-size-xs);
  color: var(--text-secondary);
}
.action-arrow {
  font-size: 48rpx;
  color: var(--text-hint);
  flex-shrink: 0;
}
.action-divider {
  height: 1rpx;
  background: var(--border-color);
  margin: 0 24rpx;
}

/* 危险操作 */
.danger-section { margin-top: 40rpx; }
.danger-item {
  padding: 24rpx; background: var(--bg-card); border-radius: var(--border-radius-lg);
  text-align: center;
}
.danger-text { color: #FF6B6B; font-size: var(--font-size-sm); font-weight: 500; }


