/* add-record 页面样式 */
.add-record {
  min-height: 100vh;
  background: var(--bg-primary);
  padding-bottom: 180rpx;
}

/* 顶部类型选择 */
.type-bar {
  position: sticky; top: 0; z-index: 10;
  background: var(--bg-card);
  padding: 16rpx 0;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
}
.type-scroll { white-space: nowrap; }
.type-tabs {
  display: inline-flex; gap: 8rpx;
  padding: 0 24rpx;
}
.type-tab {
  display: inline-flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 16rpx 28rpx; border-radius: var(--border-radius-lg);
  background: var(--bg-primary); transition: all var(--transition-fast);
  min-width: 100rpx;
}
.type-tab-active {
  background: var(--accent); box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
  transform: scale(1.05);
}
.type-tab-active .type-label { color: #fff !important; font-weight: 600; }
.type-icon { font-size: 36rpx; margin-bottom: 6rpx; }
.type-label { font-size: 26rpx; color: var(--text-secondary); }

/* 时间选择 */
.time-section {
  display: flex; align-items: center; justify-content: space-between;
  margin: 24rpx 24rpx 0; padding: 24rpx;
  background: var(--bg-card); border-radius: var(--border-radius-lg);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}
.time-label {
  display: flex; align-items: center; gap: 8rpx;
  font-size: var(--font-size-sm); color: var(--text-secondary);
}
.time-icon { font-size: 32rpx; }
.time-display {
  display: flex; align-items: center; gap: 12rpx;
}
.time-text {
  font-size: var(--font-size-lg); font-weight: 600; color: var(--text-primary);
}
.time-edit {
  font-size: var(--font-size-xs); color: var(--color-primary);
  padding: 4rpx 16rpx; background: rgba(255, 140, 107, 0.1);
  border-radius: var(--border-radius-xl);
}

/* 表单区域 */
.form-section {
  margin: 24rpx; padding: 32rpx;
  background: var(--bg-card); border-radius: var(--border-radius-xl);
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.03);
}
.form-title {
  display: flex; align-items: center; gap: 8rpx;
  margin-bottom: 24rpx; padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(0,0,0,0.05);
}
.form-title-icon { font-size: 36rpx; }
.form-title text { font-size: var(--font-size-lg); font-weight: 600; color: var(--text-primary); }

/* 备注区域 */
.note-section {
  margin: 0 24rpx;
  background: var(--bg-card); border-radius: var(--border-radius-xl);
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}
.note-toggle {
  display: flex; align-items: center; padding: 24rpx;
}
.note-icon { font-size: 32rpx; margin-right: 8rpx; }
.note-label { font-size: var(--font-size-sm); color: var(--text-primary); flex: 1; }
.note-arrow { font-size: var(--font-size-xs); color: var(--text-hint); }
.note-area {
  padding: 0 24rpx 24rpx;
}
.note-input {
  width: 100%; height: 160rpx; background: var(--bg-primary);
  border-radius: var(--border-radius-md); padding: 20rpx;
  font-size: var(--font-size-sm); box-sizing: border-box;
  line-height: 1.6;
}
.note-count {
  text-align: right; font-size: 20rpx; color: var(--text-hint);
  margin-top: 8rpx;
}

/* 底部提交栏 */
.submit-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: var(--bg-card); padding: 16rpx 24rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.05);
  z-index: 100;
}
.submit-hint {
  text-align: center; font-size: var(--font-size-xs); color: #FF6B6B;
  margin-bottom: 8rpx;
}
.submit-btn {
  width: 100%; height: 88rpx; line-height: 88rpx;
  background: linear-gradient(135deg, #FF8C6B, #FF6B4A);
  color: #fff; font-size: var(--font-size-lg); font-weight: 600;
  border-radius: var(--border-radius-xl); border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 74, 0.3);
  transition: all var(--transition-fast);
}
.submit-btn[disabled] {
  opacity: 0.6; box-shadow: none;
}
.submit-btn:active:not([disabled]) {
  transform: scale(0.98);
}


