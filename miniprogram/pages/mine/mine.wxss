/* 我的页面样式 */
.mine-page {
  min-height: 100vh; background: var(--bg-primary);
}

/* 用户信息卡 */
.user-card {
  display: flex; align-items: center; gap: 24rpx;
  margin: 24rpx; padding: 32rpx;
  background: linear-gradient(135deg, #FFB088, #FF8C6B);
  border-radius: var(--border-radius-xl);
  box-shadow: 0 8rpx 32rpx rgba(255, 140, 107, 0.25);
  cursor: pointer;
  transition: opacity 0.2s;
}
.user-card-hover {
  opacity: 0.85;
}
.user-avatar {
  width: 96rpx; height: 96rpx; border-radius: 50%;
  background: rgba(255,255,255,0.25); overflow: hidden;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.avatar-img { width: 100%; height: 100%; }
.avatar-emoji { font-size: 48rpx; }
.user-info { display: flex; flex-direction: column; color: #fff; }
.user-name { font-size: var(--font-size-lg); font-weight: 700; }
.user-family { font-size: var(--font-size-xs); opacity: 0.85; margin-top: 4rpx; }

/* 菜单区块 */
.menu-section {
  margin: 16rpx 24rpx; background: var(--bg-card);
  border-radius: var(--border-radius-lg); overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}
.menu-item {
  display: flex; align-items: center; gap: 16rpx;
  padding: 28rpx 24rpx; border-bottom: 1rpx solid rgba(0,0,0,0.04);
}
.menu-item:last-child { border-bottom: none; }
.menu-item:active { background: rgba(0,0,0,0.02); }
.menu-icon { font-size: 32rpx; width: 40rpx; text-align: center; }
.menu-text { flex: 1; font-size: var(--font-size-sm); color: var(--text-primary); }
.menu-arrow { font-size: 28rpx; color: var(--text-hint); }

/* 开关 */
.menu-switch {
  width: 80rpx; height: 44rpx; border-radius: 22rpx;
  background: #ddd; position: relative; transition: background var(--transition-fast);
}
.switch-on { background: #FF8C6B; }
.switch-dot {
  width: 36rpx; height: 36rpx; border-radius: 50%; background: #fff;
  position: absolute; top: 4rpx; left: 4rpx;
  transition: transform var(--transition-fast);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
}
.switch-on .switch-dot { transform: translateX(36rpx); }

/* 版权信息 */
.copyright-info {
  text-align: center;
  padding: 60rpx 40rpx 80rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.copyright-text {
  font-size: var(--font-size-xs);
  color: var(--text-hint);
  line-height: 1.5;
}


