.quick-actions { padding: 0; }
.actions-title {
  font-size: var(--font-size-md); font-weight: 600; color: var(--text-primary);
  margin-bottom: 20rpx;
}
.actions-grid {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}
.action-item {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 24rpx 12rpx; border-radius: var(--border-radius-lg);
  background: var(--bg-card);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  transition: all var(--transition-fast);
}
.action-item:active { transform: scale(0.95); }
.action-icon-wrap {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  background: var(--item-bg);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 12rpx;
}
.action-icon { font-size: 40rpx; }
.action-text { font-size: var(--font-size-xs); color: var(--text-secondary); font-weight: 500; }


