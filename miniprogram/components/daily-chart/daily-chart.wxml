<view class="daily-chart">
  <view class="chart-title">{{title}}</view>
  <canvas canvas-id="{{canvasId}}" id="{{canvasId}}"
          class="chart-canvas" type="2d"
          style="width: 100%; height: {{height}}rpx;">
  </canvas>
  <!-- 只在数据点较少时（≤10）显示X轴标签 -->
  <view class="chart-labels" wx:if="{{labels.length > 0 && data.length <= 10}}">
    <text class="chart-label" wx:for="{{labels}}" wx:key="*this">{{item}}</text>
  </view>
</view>
