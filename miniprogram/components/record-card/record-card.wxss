.record-card {
  display: flex; align-items: center; gap: 24rpx;
  padding: 32rpx; background: var(--bg-card);
  border-radius: var(--border-radius-lg);
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
  transition: all var(--transition-fast);
}
.record-card:active { transform: scale(0.99); background: rgba(0,0,0,0.02); }

.card-left { flex-shrink: 0; }
.card-icon-wrap {
  width: 96rpx; height: 96rpx; border-radius: 50%;
  background: var(--card-bg);
  display: flex; align-items: center; justify-content: center;
}
.card-icon { font-size: 48rpx; }

.card-content { flex: 1; min-width: 0; }
.card-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 8rpx;
}
.card-type { font-size: var(--font-size-lg); font-weight: 600; color: var(--card-color); }
.card-time { font-size: var(--font-size-sm); color: var(--text-hint); }
.card-summary {
  font-size: var(--font-size-md); color: var(--text-secondary);
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  line-height: 1.6;
}
.card-footer { margin-top: 8rpx; }
.card-operator-info {
  display: flex; align-items: center; gap: 12rpx;
}
.operator-avatar {
  width: 56rpx; height: 56rpx; border-radius: 50%;
  background: var(--bg-primary); display: flex;
  align-items: center; justify-content: center;
  font-size: var(--font-size-xs); color: var(--text-secondary);
  flex-shrink: 0; overflow: hidden;
}
.operator-avatar .avatar-img {
  width: 100%; height: 100%; border-radius: 50%;
}
.card-operator { font-size: var(--font-size-xs); color: var(--text-hint); }

.card-arrow { flex-shrink: 0; }
.arrow-icon { font-size: 40rpx; color: var(--text-hint); }


